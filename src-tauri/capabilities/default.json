{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main", "desktop-lyrics", "wallpaper", "login-*"],
  "remote": {
    "urls": ["http://localhost:*"]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-center",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-decorations",
    "core:window:allow-start-dragging",
    "core:window:allow-is-fullscreen",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "core:window:allow-set-title",
    "core:window:allow-set-background-color",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-create-webview",
    "core:webview:allow-webview-position",
    "core:webview:allow-webview-size",
    "core:webview:allow-set-webview-position",
    "core:webview:allow-set-webview-size",
    "core:webview:allow-set-webview-focus",
    "core:webview:allow-webview-show",
    "core:webview:allow-webview-hide",
    "core:webview:allow-webview-close",
    "core:image:default",
    "window-state:default",
    "global-shortcut:default",
    "dialog:default",
    "shell:default",
    "shell:allow-open",
    "os:default",
    "process:default",
    "process:allow-restart",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "allow-window-minimize",
    "allow-window-toggle-maximize",
    "allow-window-toggle-fullscreen",
    "allow-window-close",
    "allow-window-get-state",
    "allow-window-exit-fullscreen-windowed",
    "allow-open-netease-login",
    "allow-clear-netease-login",
    "allow-open-qq-login",
    "allow-clear-qq-login",
    "allow-configure-global-hotkeys",
    "allow-desktop-lyrics-set-enabled",
    "allow-desktop-lyrics-update",
    "allow-wallpaper-set-enabled",
    "allow-wallpaper-update",
    "allow-export-json-file",
    "allow-import-json-file",
    "allow-open-update-installer",
    "allow-restart-app",
    "allow-get-tray-settings",
    "allow-set-close-to-tray",
    "allow-set-startup-enabled"
  ]
}
