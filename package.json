{
  "name": "mineradio-next",
  "productName": "Mineradio",
  "version": "2.0.0-alpha.1",
  "description": "沉浸式音乐播放器 - 模块化重构版",
  "author": "Mineradio",
  "license": "GPL-3.0",
  "private": true,
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"node scripts/wait-for-server.mjs && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win nsis",
    "electron:build:mac": "npm run build && electron-builder --mac dmg",
    "electron:build:linux": "npm run build && electron-builder --linux AppImage",
    "electron:build:all": "npm run build && electron-builder -mw",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:publish": "npm run build && electron-builder --publish always",
    "server:dev": "node --watch server/index.js",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "lint:check": "eslint . --ext .vue,.js,.ts",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "NeteaseCloudMusicApi": "^4.32.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "pinia": "^2.1.7",
    "three": "^0.185.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.8.27",
    "wait-on": "^7.2.0"
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "XxHuberrr",
      "repo": "Mineradio",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "server/**/*",
      "package.json",
      "!node_modules/**/*",
      "!**/*.map",
      "!**/node_modules/*/{test,tests,example,examples,docs,doc,benchmark,__tests__,__test__}/**",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/*.txt",
      "!**/node_modules/**/LICENSE*",
      "!**/node_modules/**/license*",
      "!server/**/*.md",
      "!electron/generate-icons.js"
    ],
    "asar": false,
    "asarUnpack": [],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Mineradio-${version}-Setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "mp3",
          "name": "MP3 Audio",
          "description": "MP3 Audio File",
          "role": "Player"
        },
        {
          "ext": "flac",
          "name": "FLAC Audio",
          "description": "FLAC Audio File",
          "role": "Player"
        },
        {
          "ext": "wav",
          "name": "WAV Audio",
          "description": "WAV Audio File",
          "role": "Player"
        },
        {
          "ext": "m4a",
          "name": "M4A Audio",
          "description": "M4A Audio File",
          "role": "Player"
        },
        {
          "ext": "ogg",
          "name": "OGG Audio",
          "description": "OGG Audio File",
          "role": "Player"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}",
      "differentialPackage": true,
      "unicode": true,
      "language": "2052"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "fileAssociations": [
        {
          "ext": "mp3",
          "name": "MP3 Audio",
          "description": "MP3 Audio File",
          "role": "viewer"
        },
        {
          "ext": "flac",
          "name": "FLAC Audio",
          "description": "FLAC Audio File",
          "role": "viewer"
        },
        {
          "ext": "wav",
          "name": "WAV Audio",
          "description": "WAV Audio File",
          "role": "viewer"
        },
        {
          "ext": "m4a",
          "name": "M4A Audio",
          "description": "M4A Audio File",
          "role": "viewer"
        }
      ]
    },
    "dmg": {
      "title": "Mineradio ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Audio",
      "synopsis": "沉浸式音乐播放器",
      "description": "Mineradio - 沉浸式音乐播放器",
      "fileAssociations": [
        {
          "ext": "mp3",
          "name": "MP3 Audio",
          "description": "MP3 Audio File",
          "mimeType": "audio/mpeg"
        },
        {
          "ext": "flac",
          "name": "FLAC Audio",
          "description": "FLAC Audio File",
          "mimeType": "audio/flac"
        },
        {
          "ext": "wav",
          "name": "WAV Audio",
          "description": "WAV Audio File",
          "mimeType": "audio/wav"
        },
        {
          "ext": "m4a",
          "name": "M4A Audio",
          "description": "M4A Audio File",
          "mimeType": "audio/mp4"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "XxHuberrr",
        "repo": "Mineradio",
        "releaseType": "prerelease"
      }
    ]
  }
}
